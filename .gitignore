# .gitignore for Table Upload Manager WordPress Plugin

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor directories
.idea/
.vscode/
*.sublime-workspace
*.sublime-project

# Composer (if added later)
/vendor/
composer.lock

# npm (if added later)
/node_modules/
package-lock.json
yarn.lock

# Build output
/dist/
/build/

# WordPress uploads that may sneak in
*.log
*.zip
*.tar.gz

# Local environment config
.env
.env.*
wp-config.php
